# FREE TIER ONLY - No paid APIs needed

# REQUIRED: Groq API (Free tier: 20 requests/min, 1,440,000 tokens/day)
# Get key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_key_here

# REQUIRED: HuggingFace API (Free tier available)
# Get token at: https://huggingface.co/settings/tokens
HF_API_TOKEN=hf_your_huggingface_token_here

# REQUIRED: Supabase (Free tier: 500MB DB, 2GB bandwidth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
